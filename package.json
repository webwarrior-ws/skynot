{
  "name": "skynot",
  "version": "0.0.4",
  "description": "Installer for pi-coding-agent embedded as a simple NPX tool to set up a user named `aidev`, and download Pi inside its $HOME (launcher script will be called `spi` instead of `pi`)",
  "main": "dist/index.js",
  "bin": {
    "skynot": "dist/index.js"
  },
  "scripts": {
    "build": "npm install && npx tsc",
    "prepublishOnly": "npm run build",
    "format": "npm install && npx --no-install prettier --quote-props=consistent --write ./src/**/*.ts",
    "exec": "npm run build && node dist/index.js"
  },
  "keywords": [
    "pi",
    "coding-agent",
    "ai",
    "llm",
    "cli",
    "tui",
    "agent",
    "installer"
  ],
  "author": "Andres G. Aragoneses",
  "license": "AGPL",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tarsgate/skynot.git"
  },
  "bugs": {
    "url": "https://github.com/tarsgate/skynot/issues"
  },
  "homepage": "https://github.com/tarsgate/skynot#readme",
  "dependencies": {
    "fp-sdk": "0.1.1",
    "commander": "^11.0.0"
  },
  "devDependencies": {
    "prettier": "2.8.3",
    "@types/node": "^20.12.0",
    "typescript": "^5.3.3"
  }
}
